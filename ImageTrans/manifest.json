{
  "manifest_version": 3,
  "name": "__MSG_ext_name__",
  "version": "5.2",
  "description": "__MSG_ext_desc__",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "admin@basiccat.org",
      "strict_min_version": "115.0",
      "data_collection_permissions": {"required": []}
    }
  },
  "permissions": ["storage", "activeTab", "contextMenus", "clipboardWrite", "webRequest", "webRequestBlocking"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "options.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["getImage.js"],
      "css": ["cursor.css"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "imagetrans.png"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "MacCtrl+Shift+V"
      },
      "description": "__MSG_ext_command_desc__"
    }
  },
  "icons": {
    "16": "imagetrans-16.png",
    "48": "imagetrans-48.png",
    "128": "imagetrans-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "homepage_url": "https://www.basiccat.org/imagetrans",
  "web_accessible_resources": [
    {
      "resources": [
        "_locales/*",
        "paddleocr/opencv.js.gz",
        "paddleocr/ort.min.js",
        "paddleocr/esearch-ocr/dist/esearch-ocr.umd.js",
        "paddleocr/page-ocr.js",
        "paddleocr/ppocr_v5_mobile_det.onnx",
        "paddleocr/ppocr_v5_mobile_rec.onnx",
        "paddleocr/ppocrv5_dict.txt",
        "paddleocr/ort-wasm-simd-threaded.jsep.mjs",
        "paddleocr/ort-wasm-simd-threaded.jsep.wasm",
        "paddleocr/model.onnx",
        "paddleocr/tesseract.min.js",
        "paddleocr/worker.min.js",
        "paddleocr/tesseract-core-simd-lstm.wasm.js",
        "paddleocr/jpn_vert.traineddata.gz"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}